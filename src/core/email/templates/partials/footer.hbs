</td><!-- cierra padding body -->
                </tr><!-- cierra fila body -->

                <!-- ── Footer ── -->
                <tr>
                    <td style="background-color:#F5F8FF;border-top:1px solid #E2EAF4;padding:22px 40px;">
                        <!-- Sitio web de la empresa -->
                        {{#if empresaWeb}}
                        <p style="margin:0 0 12px;text-align:center;">
                            <a href="{{empresaWeb}}"
                               style="font-size:12px;font-weight:600;color:#5B80C0;
                                      text-decoration:none;">
                                {{empresaWeb}}
                            </a>
                        </p>
                        {{/if}}

                        <!-- Empresa + dirección -->
                        <p style="margin:0 0 6px;text-align:center;font-size:11px;
                                  color:#A0AABF;line-height:1.6;">
                            <strong style="color:#8898B4;font-weight:600;">{{appName}}</strong>
                            &nbsp;&middot;&nbsp;
                            {{#if empresaDireccion}}{{empresaDireccion}}{{else}}Quito, Ecuador{{/if}}
                        </p>

                        <!-- Teléfono + email de contacto -->
                        {{#if empresaTelefono}}
                        <p style="margin:0 0 6px;text-align:center;font-size:11px;
                                  color:#A0AABF;line-height:1.6;">
                            {{empresaTelefono}}                           
                        </p>
                        {{/if}}

                        <!-- Copyright -->
                        <p style="margin:0;text-align:center;font-size:10px;
                                  color:#BFC8D8;line-height:1.5;letter-spacing:0.03em;">
                            &copy; {{year}} {{appName}}. Todos los derechos reservados.
                        </p>
                    </td>
                </tr>

            </table><!-- cierra em-wrapper -->

        </td>
    </tr>
</table>
</body>
</html>