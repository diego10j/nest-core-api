{{> partials/header
    title="Confirmación de envío"
    heroLabel="Guía de Transporte"
    subtitle="Adjunto encontrarás la guía de envío con los datos de la entrega."
}}

<!-- ── Saludo ── -->
<p style="margin:0 0 6px;font-size:15px;font-weight:700;color:#0D1F4E;">
    Hola, {{capitalizeWords cliente}} 👋
</p>
<p style="margin:0 0 22px;font-size:14px;line-height:1.75;color:#4A5E7A;">
    Tu env&iacute;o ha sido registrado. A continuaci&oacute;n te compartimos los datos de la entrega.
    {{#if esTransportePropio}}
    El traslado se realiza con veh&iacute;culo propio. La gu&iacute;a firmada se adjunta como comprobante de entrega.
    {{/if}}
</p>

<!-- ── Banner de estado ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;margin:0 0 24px;">
    <tr>
        <td style="background-color:{{bannerColor}};border-left:3px solid {{bannerBorder}};
                   border-radius:0 8px 8px 0;padding:12px 16px;">
            <p style="margin:0;font-size:13px;font-weight:700;color:{{bannerText}};">
                {{bannerIcon}}&nbsp; Estado: {{estado}}
            </p>
        </td>
    </tr>
</table>

<!-- ── Sección label ── -->
<p style="font-size:10px;font-weight:700;text-transform:uppercase;
          letter-spacing:0.12em;color:#8898B4;margin:0 0 10px;">
    Datos del env&iacute;o
</p>

<!-- ── Info card ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;border:1px solid #E2EAF4;
              border-radius:12px;overflow:hidden;margin:0 0 22px;">

    <!-- Card header -->
    <tr>
        <td colspan="2"
            style="background-color:#F5F8FF;padding:10px 16px;
                   border-bottom:1px solid #E2EAF4;
                   font-size:11px;font-weight:700;
                   letter-spacing:0.10em;text-transform:uppercase;color:#1A56DB;">
            Informaci&oacute;n de Entrega
        </td>
    </tr>

    <!-- Fila 1: Factura + Fecha -->
    <tr>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               border-right:1px solid #EEF2F8;vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Factura</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;
                         font-family:'DM Mono',monospace;
                         background-color:#EEF3FF;border-radius:4px;
                         padding:2px 7px;display:inline-block;">
                #{{secuencial}}
            </span>
        </td>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Fecha</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{formatDate fechaEnvio}}</span>
        </td>
    </tr>

    <!-- Fila 2: Cliente -->
    <tr>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               border-right:1px solid #EEF2F8;vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Cliente</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{cliente}}</span>
        </td>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Identificaci&oacute;n</span>
            <span style="font-size:13px;color:#4A5E7A;">{{identificacion}}</span>
        </td>
    </tr>

    <!-- Fila 3: Tipo transporte + Empresa/Propio -->
    <tr>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               border-right:1px solid #EEF2F8;vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Tipo de transporte</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{tipoTransporte}}</span>
        </td>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Transporte</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{nombreTransporte}}</span>
        </td>
    </tr>

    <!-- Fila 4: Vehículo + Chofer (condicional) -->
    {{#if placa}}
    <tr>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               border-right:1px solid #EEF2F8;vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Veh&iacute;culo</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{placa}}{{#if vehiculo}} - {{vehiculo}}{{/if}}</span>
        </td>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Chofer</span>
            <span style="font-size:13px;color:#4A5E7A;">{{#if chofer}}{{chofer}}{{else}}—{{/if}}</span>
        </td>
    </tr>
    {{/if}}


</table>

<!-- ── Aviso guía adjunta ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;margin:0 0 20px;">
    <tr>
        <td style="background-color:#F5F8FF;border:1px solid #E2EAF4;
                   border-radius:8px;padding:14px 16px;">
            <p style="margin:0;font-size:13px;line-height:1.75;color:#4A5E7A;">
                📎&nbsp; La gu&iacute;a de transporte se encuentra en la
                <strong style="color:#0D1F4E;">imagen adjunta</strong> a este correo.
            </p>
        </td>
    </tr>
</table>

<!-- ── Observaciones (condicional) ── -->
{{#if comentario}}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;margin:0 0 20px;">
    <tr>
        <td style="background-color:#FFFBEA;border-left:3px solid #E8A000;
                   border-radius:0 8px 8px 0;padding:12px 16px;
                   font-size:13px;line-height:1.65;color:#6B4F00;">
            <strong style="display:block;margin-bottom:4px;font-size:11px;
                           text-transform:uppercase;letter-spacing:0.08em;color:#92400E;">
                Observaciones
            </strong>
            {{comentario}}
        </td>
    </tr>
</table>
{{/if}}

<!-- ── Firma ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;border-top:1px solid #E8EEF6;margin-top:28px;">
    <tr>
        <td style="padding:20px 0 32px;">
            <p style="margin:0 0 6px;font-size:13px;color:#8898B4;line-height:1.6;">
                Atentamente,
            </p>
            <p style="margin:0 0 10px;font-size:14px;font-weight:700;color:#0D1F4E;
                      line-height:1.6;">
                {{appName}}
            </p>
            {{#if empresaWeb}}
            <p style="margin:4px 0 0;font-size:13px;line-height:1.6;">
                <span style="color:#4A5E7A;">&#127760;&ensp;</span>
                <a href="{{empresaWeb}}" style="color:#1A56DB;text-decoration:none;">{{empresaWebDisplay}}</a>
            </p>
            {{/if}}
        </td>
    </tr>
</table>

{{> partials/footer}}
