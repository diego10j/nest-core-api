{{> partials/header
    title="Tu proforma está lista"
    heroLabel="Cotización Comercial"
    subtitle="Revisa los datos principales y el PDF adjunto para el detalle completo."
}}

<!-- ── Saludo ── -->
<p style="margin:0 0 6px;font-size:15px;font-weight:700;color:#0D1F4E;">
    Hola, {{solicitante}} 👋
</p>
<p style="margin:0 0 22px;font-size:14px;line-height:1.75;color:#4A5E7A;">
    Es un gusto atenderte. Tu proforma est&aacute; lista y esperamos que se ajuste a lo que necesitas. Rev&iacute;sala con calma y si tienes alguna pregunta o deseas hacer alg&uacute;n ajuste, estamos aqu&iacute; para ayudarte en lo que necesites.
</p>

<!-- ── Banner de estado ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;margin:0 0 24px;">
    <tr>
        <td style="background-color:#ECFDF5;border-left:3px solid #059669;
                   border-radius:0 8px 8px 0;padding:12px 16px;">
            <p style="margin:0;font-size:13px;font-weight:700;color:#065F46;">
                ✅&nbsp; Proforma emitida y lista para confirmaci&oacute;n comercial
            </p>
        </td>
    </tr>
</table>

<!-- ── Sección label ── -->
<p style="font-size:10px;font-weight:700;text-transform:uppercase;
          letter-spacing:0.12em;color:#8898B4;margin:0 0 10px;">
    Datos de la proforma
</p>

<!-- ── Info card ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;border:1px solid #E2EAF4;
              border-radius:12px;overflow:hidden;margin:0 0 22px;">

    <!-- Card header -->
    <tr>
        <td colspan="2"
            style="background-color:#F5F8FF;padding:10px 16px;
                   border-bottom:1px solid #E2EAF4;
                   font-size:11px;font-weight:700;
                   letter-spacing:0.10em;text-transform:uppercase;color:#1A56DB;">
            Resumen del Documento
        </td>
    </tr>

    <!-- Fila 1: Número + Fecha -->
    <tr>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               border-right:1px solid #EEF2F8;vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">N&uacute;mero</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;
                         font-family:'DM Mono',monospace;
                         background-color:#EEF3FF;border-radius:4px;
                         padding:2px 7px;display:inline-block;">
                #{{secuencial}}
            </span>
        </td>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Fecha</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{formatDate fecha}}</span>
        </td>
    </tr>

    <!-- Fila 2: Cliente (fila completa) -->
    <tr>
        <td colspan="2" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Cliente</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{solicitante}}</span>
        </td>
    </tr>

    <!-- Fila 3: Validez + Forma de pago (condicional) -->
    {{#if validez}}
    <tr>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               border-right:1px solid #EEF2F8;vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Validez</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{validez}}</span>
        </td>
        <td width="50%" style="padding:11px 16px;border-bottom:1px solid #EEF2F8;
                               vertical-align:top;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.07em;
                         color:#8898B4;margin-bottom:4px;">Forma de pago</span>
            <span style="font-size:13px;font-weight:700;color:#0D1F4E;">{{formaPago}}</span>
        </td>
    </tr>
    {{/if}}

    <!-- Fila total — highlight -->
    <tr>
        <td colspan="2"
            style="padding:14px 16px;background-color:#F5F8FF;vertical-align:middle;">
            <span style="display:block;font-size:10px;font-weight:700;
                         text-transform:uppercase;letter-spacing:0.10em;
                         color:#8898B4;margin-bottom:6px;">Total de la proforma</span>
            <span style="font-size:28px;font-weight:800;color:#1A56DB;
                         letter-spacing:-0.02em;line-height:1;">
                {{total}}
            </span>
        </td>
    </tr>

</table>

<!-- ── Aviso PDF adjunto ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;margin:0 0 20px;">
    <tr>
        <td style="background-color:#F5F8FF;border:1px solid #E2EAF4;
                   border-radius:8px;padding:14px 16px;">
            <p style="margin:0;font-size:13px;line-height:1.75;color:#4A5E7A;">
                📎&nbsp; El detalle de productos, condiciones comerciales y t&eacute;rminos
                se encuentran en el
                <strong style="color:#0D1F4E;">PDF adjunto</strong>.
            </p>
        </td>
    </tr>
</table>

<!-- ── Observaciones (condicional) ── -->
{{#if observacion}}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;margin:0 0 20px;">
    <tr>
        <td style="background-color:#FFFBEA;border-left:3px solid #E8A000;
                   border-radius:0 8px 8px 0;padding:12px 16px;
                   font-size:13px;line-height:1.65;color:#6B4F00;">
            <strong style="display:block;margin-bottom:4px;font-size:11px;
                           text-transform:uppercase;letter-spacing:0.08em;color:#92400E;">
                Observaciones
            </strong>
            {{observacion}}
        </td>
    </tr>
</table>
{{/if}}

<!-- ── Firma ── -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="border-collapse:collapse;border-top:1px solid #E8EEF6;margin-top:28px;">
    <tr>
        <td style="padding:20px 0 32px;">
            <p style="margin:0 0 6px;font-size:13px;color:#8898B4;line-height:1.6;">
                Atentamente,
            </p>
            {{#if vendedor}}
            <p style="margin:0 0 10px;font-size:14px;font-weight:700;color:#0D1F4E;
                      line-height:1.6;text-transform:capitalize;">
                {{ capitalizeWords vendedor}}
            </p>
            {{/if}}
            {{#if vendedorCorreo}}
            <p style="margin:4px 0;font-size:13px;line-height:1.6;">
                <span style="color:#4A5E7A;">&#9993;&ensp;</span>
                <a href="mailto:{{vendedorCorreo}}" style="color:#1A56DB;text-decoration:none;">{{vendedorCorreo}}</a>
            </p>
            {{/if}}
            {{#if vendedorMovil}}
            <p style="margin:4px 0;font-size:13px;line-height:1.6;">
                <span style="color:#4A5E7A;">&#128241;&ensp;</span>
                <a href="https://wa.me/{{whatsappNumber vendedorMovil}}" style="color:#25D366;text-decoration:none;font-weight:600;">{{vendedorMovil}}</a>
                <span style="font-size:10px;color:#94A3B8;margin-left:6px;">WhatsApp</span>
            </p>
            {{/if}}
            {{#if empresaWeb}}
            <p style="margin:4px 0 0;font-size:13px;line-height:1.6;">
                <span style="color:#4A5E7A;">&#127760;&ensp;</span>
                <a href="{{empresaWeb}}" style="color:#8898B4;text-decoration:none;">{{empresaWeb}}</a>
            </p>
            {{/if}}
        </td>
    </tr>
</table>

{{> partials/footer}}